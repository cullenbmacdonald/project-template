#!/bin/sh
# Pre-commit hook: runs checks for changed directories
# Only runs checks for code that was touched in the commit

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

# Check which directories have staged changes
# Customize these patterns for your project structure
BACKEND_CHANGED=$(echo "$STAGED_FILES" | grep -E '^backend/' || true)
FRONTEND_CHANGED=$(echo "$STAGED_FILES" | grep -E '^frontend/' || true)

if [ -z "$BACKEND_CHANGED" ] && [ -z "$FRONTEND_CHANGED" ]; then
    echo "No backend or frontend files staged. Skipping checks."
    exit 0
fi

echo "Running pre-commit checks..."

# Backend checks (only if backend files changed)
if [ -n "$BACKEND_CHANGED" ]; then
    echo ""
    echo "=== Backend ==="
    cd "$REPO_ROOT/backend"

    # Run formatting first and auto-add any changes
    # Customize these commands for your tech stack
    echo "Running format..."
    make fmt 2>/dev/null || true

    # Check if fmt made any changes and add them to the commit
    if ! git diff --quiet; then
        echo "Formatting changes detected, adding to commit..."
        git add -u
    fi

    # Run lint
    echo "Running lint..."
    make lint
    if [ $? -ne 0 ]; then
        echo "Backend lint failed. Please fix the issues before committing."
        exit 1
    fi
else
    echo ""
    echo "=== Backend ==="
    echo "No backend files changed. Skipping."
fi

# Frontend checks (only if frontend files changed)
if [ -n "$FRONTEND_CHANGED" ]; then
    echo ""
    echo "=== Frontend ==="
    cd "$REPO_ROOT/frontend"

    # Run TypeScript type checking (if using TypeScript)
    if [ -f "tsconfig.json" ]; then
        echo "Running TypeScript check..."
        npx tsc -b
        if [ $? -ne 0 ]; then
            echo "TypeScript check failed. Please fix the issues before committing."
            exit 1
        fi
    fi

    # Run ESLint
    echo "Running lint..."
    make lint
    if [ $? -ne 0 ]; then
        echo "Frontend lint failed. Please fix the issues before committing."
        exit 1
    fi
else
    echo ""
    echo "=== Frontend ==="
    echo "No frontend files changed. Skipping."
fi

echo ""
echo "Pre-commit checks passed."
