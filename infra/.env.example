# Production Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Domain Configuration
# =============================================================================

# Your domain name (required for TLS certificates)
DOMAIN=example.com

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

DB_USER=app
DB_PASSWORD=CHANGE_ME_GENERATE_RANDOM_PASSWORD
DB_NAME=app

# =============================================================================
# Application
# =============================================================================

# JWT secret for API authentication (generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: console (human-readable) or json (structured)
LOG_FORMAT=json

# =============================================================================
# Versioning
# =============================================================================

# Docker image version tag
VERSION=latest

# GitHub repository (for image naming)
GITHUB_REPOSITORY=your-username/your-repo
